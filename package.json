{
  "name": "secure-sftp",
  "displayName": "Secure SFTP",
  "description": "Secure SFTP file transfer for VS Code with modern security practices",
  "version": "0.2.0",
  "publisher": "secure-sftp",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "sftp",
    "ssh",
    "ftp",
    "upload",
    "remote",
    "sync",
    "secure"
  ],
  "activationEvents": [
    "onCommand:secureSftp.connect",
    "onCommand:secureSftp.disconnect",
    "onCommand:secureSftp.uploadFile",
    "onCommand:secureSftp.uploadFolder",
    "onCommand:secureSftp.downloadFile",
    "onCommand:secureSftp.sync",
    "onCommand:secureSftp.configure",
    "onCommand:secureSftp.setPassword",
    "onCommand:secureSftp.setPassphrase",
    "onCommand:secureSftp.clearCredentials",
    "onCommand:secureSftp.viewHostKeys"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "secureSftp.connect",
        "title": "Secure SFTP: Connect to Server"
      },
      {
        "command": "secureSftp.disconnect",
        "title": "Secure SFTP: Disconnect"
      },
      {
        "command": "secureSftp.uploadFile",
        "title": "Secure SFTP: Upload Current File"
      },
      {
        "command": "secureSftp.uploadFolder",
        "title": "Secure SFTP: Upload Folder"
      },
      {
        "command": "secureSftp.downloadFile",
        "title": "Secure SFTP: Download File"
      },
      {
        "command": "secureSftp.sync",
        "title": "Secure SFTP: Sync Folders"
      },
      {
        "command": "secureSftp.configure",
        "title": "Secure SFTP: Open Configuration"
      },
      {
        "command": "secureSftp.setPassword",
        "title": "Secure SFTP: Store Credentials"
      },
      {
        "command": "secureSftp.setPassphrase",
        "title": "Secure SFTP: Store Private Key Passphrase"
      },
      {
        "command": "secureSftp.clearCredentials",
        "title": "Secure SFTP: Clear Stored Credentials"
      },
      {
        "command": "secureSftp.viewHostKeys",
        "title": "Secure SFTP: View Known Hosts"
      }
    ],
    "configuration": {
      "title": "Secure SFTP",
      "properties": {
        "secureSftp.configs": {
          "type": "array",
          "default": [],
          "description": "SFTP server configurations (credentials stored separately in OS keychain)",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Display name for this connection"
              },
              "host": {
                "type": "string",
                "description": "Server hostname or IP address"
              },
              "port": {
                "type": "integer",
                "default": 22,
                "description": "SSH port"
              },
              "username": {
                "type": "string",
                "description": "SSH username"
              },
              "remotePath": {
                "type": "string",
                "description": "Remote path to sync to"
              },
              "authMethod": {
                "type": "string",
                "enum": ["password", "privateKey", "agent"],
                "default": "agent",
                "description": "Authentication method"
              },
              "privateKeyPath": {
                "type": "string",
                "description": "Path to private key file"
              },
              "uploadOnSave": {
                "type": "boolean",
                "default": false,
                "description": "Upload files automatically when saved"
              },
              "watcher": {
                "type": "object",
                "description": "File watcher configuration for automatic sync",
                "properties": {
                  "files": {
                    "type": "string",
                    "default": "**/*",
                    "description": "Glob pattern for files to watch (e.g., '**/*')"
                  },
                  "autoUpload": {
                    "type": "boolean",
                    "default": true,
                    "description": "Automatically upload new/modified files"
                  },
                  "autoDelete": {
                    "type": "boolean",
                    "default": false,
                    "description": "Automatically delete remote files when local files are deleted"
                  },
                  "debounceDelay": {
                    "type": "integer",
                    "default": 500,
                    "minimum": 100,
                    "maximum": 10000,
                    "description": "Debounce delay in milliseconds (default: 500)"
                  },
                  "excludePatterns": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "default": [],
                    "description": "Additional glob patterns to exclude (node_modules, .git already excluded)"
                  }
                }
              },
              "ignore": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Patterns to ignore during sync"
              },
              "strictHostKeyChecking": {
                "type": "boolean",
                "default": true,
                "description": "Require host key verification"
              }
            },
            "required": ["name", "host", "username", "remotePath", "authMethod"]
          }
        },
        "secureSftp.logLevel": {
          "type": "string",
          "enum": [
            "error",
            "warn",
            "info",
            "debug"
          ],
          "default": "info",
          "description": "Log level (sensitive data is NEVER logged at any level)"
        },
        "secureSftp.allowLocalhost": {
          "type": "boolean",
          "default": false,
          "description": "Allow localhost/127.0.0.1 connections for development only"
        },
        "secureSftp.uploadOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically upload files when saved"
        },
        "secureSftp.hop": {
          "type": "object",
          "description": "Jump host (proxy) configuration",
          "properties": {
            "host": {
              "type": "string",
              "description": "Jump host hostname or IP"
            },
            "port": {
              "type": "integer",
              "default": 22,
              "description": "Jump host SSH port"
            },
            "username": {
              "type": "string",
              "description": "Jump host username"
            },
            "authMethod": {
              "type": "string",
              "enum": [
                "password",
                "privateKey",
                "agent"
              ],
              "default": "agent",
              "description": "Authentication method for jump host"
            },
            "privateKeyPath": {
              "type": "string",
              "description": "Path to private key for jump host"
            },
            "algorithms": {
              "$ref": "#/definitions/algorithms"
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "prepare": "husky install"
  },
  "dependencies": {
    "ssh2": "^1.15.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ssh2": "^1.15.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.56.0",
    "eslint-plugin-security": "^2.1.0",
    "husky": "^8.0.3",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/popchenk/vscode-sftp.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/popchenk/vscode-sftp/issues"
  },
  "homepage": "https://github.com/popchenk/vscode-sftp#readme"
}